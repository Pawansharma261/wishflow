{
  "expo": {
    "name": "WishFlow",
    "slug": "wishflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "scheme": "wishflow",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0c29"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kptech.wishflow",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "WishFlow uses the camera only to help you scan a QR code to link your WhatsApp account for personal celebration wish delivery.",
        "NSPhotoLibraryUsageDescription": "WishFlow may access photos to let you add a personal photo to your celebration wishes.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["wishflow"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0f0c29"
      },
      "package": "com.kptech.wishflow",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "wishflow"
            },
            {
              "scheme": "https",
              "host": "wishflow-backend-uyd2.onrender.com",
              "pathPrefix": "/api/integrations/instagram/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "417ea5a1-df77-4987-bb21-3c2e0c51e613"
      }
    },
    "owner": "wishflow"
  }
}
