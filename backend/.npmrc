# Speed up Render/npm deploys:
# Skip optional native compilation (canvas, sharp, etc.) that aren't needed
omit=optional
# Don't run post-install scripts for packages that have heavy native builds
ignore-scripts=false
# Use legacy peer deps to avoid resolution conflicts with baileys rc packages
legacy-peer-deps=true
# Increase network timeout for slow Render build VMs
fetch-timeout=120000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=60000
